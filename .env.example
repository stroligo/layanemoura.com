# URL pública do site (SEO: canonical, Open Graph, sitemap, robots)
NUXT_PUBLIC_SITE_URL=https://layanemoura.com

# Formulário de contacto — envio real por SMTP (servidor)
# Sem SMTP_HOST + SMTP_USER + SMTP_PASS, o formulário responde 503.
# Hostinger: hPanel → E-mails → senha da caixa hi@layanemoura.com
# Guia: Projeto/email-hostinger.md
CONTACT_TO_EMAIL=hi@layanemoura.com
CONTACT_FROM_EMAIL=hi@layanemoura.com
CONTACT_FROM_NAME=Layane Moura Website
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hi@layanemoura.com
SMTP_PASS=

# WhatsApp — aviso quando alguém envia o formulário (opcional)
# CallMeBot (grátis): https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 1) Layane adiciona o bot CallMeBot no WhatsApp e obtém a API key
# 2) Ative WHATSAPP_NOTIFY_ENABLED=true e preencha CALLMEBOT_API_KEY
WHATSAPP_NOTIFY_ENABLED=false
WHATSAPP_NOTIFY_PHONE=5563992429380
CALLMEBOT_API_KEY=
# Alternativa: URL de webhook (Make, n8n, Zapier) que encaminha para WhatsApp
WHATSAPP_NOTIFY_WEBHOOK=

# Nuxt Studio — produção (https://nuxt.studio/setup)
# Obrigatório no build da Hostinger (sem isto /_studio dá 404):
STUDIO_REPOSITORY_OWNER=seu-usuario-github
STUDIO_REPOSITORY_REPO=layanemoura.com
STUDIO_REPOSITORY_BRANCH=main

# GitHub OAuth — obrigatório em produção para abrir https://seu-dominio/_studio
# Crie em https://github.com/settings/developers → OAuth App
# Callback (exatamente isto — não use /_studio/...):
# https://layanemoura.com/__nuxt_studio/auth/github
# Apenas no servidor — não commitar .env; não usar prefixo NUXT_PUBLIC_
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=
